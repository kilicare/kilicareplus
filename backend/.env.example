# ==========================================
# KILICARE+ BACKEND ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ==========================================
# CORE DJANGO SETTINGS
# ==========================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True  # Set to False in production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,your-production-domain.onrender.com

# ==========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
# Use DATABASE_URL for both local and production
# Django automatically switches based on this single variable

# LOCAL DEVELOPMENT:
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# Example: DATABASE_URL=postgresql://postgres:password@localhost:5432/kilicarego

# PRODUCTION (Render):
# DATABASE_URL is automatically provided by Render PostgreSQL service
# Do NOT set this manually in Render - use the internal database URL

DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ==========================================
# REDIS CONFIGURATION (Optional - for production)
# ==========================================
REDIS_HOST=localhost
REDIS_URL=redis://localhost:6379/0
USE_REDIS_CHANNELS=False  # Set to True in production with Redis
USE_REDIS_CACHE=False  # Set to True in production with Redis

# ==========================================
# CORS & CSRF SETTINGS
# ==========================================
# Add your frontend URLs here (comma-separated)
# LOCAL: http://localhost:3000,http://127.0.0.1:3000
# PRODUCTION: https://kilicareplus.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://kilicareplus.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://kilicareplus.vercel.app

# ==========================================
# BASE URLs
# ==========================================
# LOCAL: http://localhost:8000
# PRODUCTION: https://your-app.onrender.com
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ==========================================
# CLOUDINARY CONFIGURATION
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==========================================
# AI CONFIGURATION (Groq)
# ==========================================
GROQ_API_KEY=your_groq_api_key
GROQ_TEXT_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# ==========================================
# PREDICTOR ENGINE
# ==========================================
PREDICTOR_URL=http://localhost:8001

# ==========================================
# M-PESA CONFIGURATION
# ==========================================
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENV=sandbox  # sandbox or production

# ==========================================
# STRIPE CONFIGURATION
# ==========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# ==========================================
# FIREBASE CONFIGURATION (Optional)
# ==========================================
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# ==========================================
# SENTRY ERROR TRACKING (Optional)
# ==========================================
SENTRY_DSN=your_sentry_dsn
SENTRY_ENVIRONMENT=production
SENTRY_SERVER_NAME=kilicarego-backend
SENTRY_RELEASE=v1.0.0
